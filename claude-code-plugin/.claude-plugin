{
  "name": "claw-rl",
  "version": "2.0.0",
  "description": "Self-Improvement System for Claude Code",
  "author": "OpenClaw Community",
  "license": "Apache-2.0",
  "homepage": "https://github.com/opensourceclaw/claw-rl",
  "repository": "https://github.com/opensourceclaw/claw-rl",
  
  "hooks": {
    "SessionStart": "./dist/hooks/SessionStartHook.js",
    "PostToolUse": "./dist/hooks/PostToolUseHook.js",
    "SessionEnd": "./dist/hooks/SessionEndHook.js"
  },
  
  "dependencies": {
    "python": ">=3.8",
    "pip-package": "claw-rl>=2.0.0"
  },
  
  "configuration": {
    "workspaceDir": {
      "type": "string",
      "default": "~/.openclaw/workspace",
      "description": "Directory for learning data"
    },
    "autoLearn": {
      "type": "boolean",
      "default": true,
      "description": "Automatically learn from feedback"
    }
  },
  
  "commands": {
    "status": {
      "description": "Get learning status",
      "usage": "claw-rl-status"
    },
    "collect": {
      "description": "Collect feedback",
      "usage": "claw-rl-collect <feedback> [--action <action>]"
    }
  }
}
